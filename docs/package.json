{
  "name": "react-tooltip-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:tooltip-style-sources": "node ./scripts/generate-tooltip-style-sources.mjs",
    "docusaurus": "docusaurus",
    "start": "yarn generate:tooltip-style-sources && docusaurus start",
    "build": "yarn generate:tooltip-style-sources && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "yarn generate:tooltip-style-sources && docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-tooltip": "5.30.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "postcss-preset-env": "^9.3.0",
    "typescript": "5.4.5"
  },
  "resolutions": {
    "webpackbar": "7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
